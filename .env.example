# Resend (https://resend.com) のAPIキー
# ダッシュボード → API Keys → Create API Key で取得
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 問い合わせの送信先 (受信したいメールアドレス)
CONTACT_TO_EMAIL=support@kodo-inc.jp

# 送信元アドレス
# - 試運転中: "Kodo Studio <onboarding@resend.dev>" (デフォルト/ドメイン認証不要)
# - 本番: Resend で kodostudio.com (またはサブドメイン) を認証してから
#         "Kodo Studio AI <noreply@kodostudio.com>" などに切り替え
CONTACT_FROM_EMAIL=Kodo Studio <onboarding@resend.dev>
