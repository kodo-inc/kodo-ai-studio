# ─── Resend (メール送信) ───
# https://resend.com の API キー (ダッシュボード → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 問い合わせの送信先 (受信したいメールアドレス)
CONTACT_TO_EMAIL=support@kodo-inc.jp

# 送信元アドレス
# - 試運転中: "Kodo Studio <onboarding@resend.dev>" (デフォルト/ドメイン認証不要)
# - 本番: Resend で kodo-studio.com を認証してから
#         "KODO AI Studio <noreply@kodo-studio.com>" に切り替え
CONTACT_FROM_EMAIL=KODO AI Studio <noreply@kodo-studio.com>

# ─── Meta Pixel (クライアントサイド計測) ───
# Events Manager → ピクセル → ピクセル ID (15桁前後の数字)
# NEXT_PUBLIC_ プレフィックスでブラウザに公開される
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Meta Conversions API (サーバーサイド計測, 推奨) ───
# Pixel 設定 → Conversions API → Generate Access Token
META_CAPI_ACCESS_TOKEN=

# (任意) サーバー側でもピクセルIDを参照したい場合用。
# 未設定時は NEXT_PUBLIC_META_PIXEL_ID を流用する
META_PIXEL_ID=
